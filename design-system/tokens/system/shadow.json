{
  "shadow": {
    "none": {
      "$value": "none",
      "$type": "shadow"
    },
    "xs": {
      "$value": "0 1px 2px rgba(44, 62, 80, 0.04)",
      "$type": "shadow"
    },
    "sm": {
      "$value": "0 1px 3px rgba(44, 62, 80, 0.06), 0 1px 2px rgba(44, 62, 80, 0.04)",
      "$type": "shadow"
    },
    "md": {
      "$value": "0 4px 12px rgba(44, 62, 80, 0.08), 0 2px 4px rgba(44, 62, 80, 0.04)",
      "$type": "shadow"
    },
    "lg": {
      "$value": "0 12px 32px rgba(44, 62, 80, 0.10), 0 4px 8px rgba(44, 62, 80, 0.06)",
      "$type": "shadow"
    },
    "xl": {
      "$value": "0 24px 64px rgba(44, 62, 80, 0.14), 0 8px 16px rgba(44, 62, 80, 0.08)",
      "$type": "shadow"
    },
    "focus": {
      "$value": "0 0 0 2px rgba(74, 107, 90, 0.30)",
      "$type": "shadow"
    },
    "focus-error": {
      "$value": "0 0 0 2px rgba(184, 92, 92, 0.30)",
      "$type": "shadow"
    },
    "inset-sm": {
      "$value": "inset 0 1px 2px rgba(44, 62, 80, 0.06)",
      "$type": "shadow"
    }
  }
}
